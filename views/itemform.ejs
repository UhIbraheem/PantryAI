<%- include('partials/head', { title: mode === 'add' ? 'Add item' : 'Edit item', active: 'inventory' }) %>

<div class="page-head">
  <div>
    <h1><%= mode === 'add' ? 'Add item' : 'Edit item' %></h1>
    <p><%= mode === 'add' ? 'Put something new in your pantry.' : `Update ${item.name}.` %></p>
  </div>
</div>

<form method="post" action="<%= mode === 'add' ? '/inventory' : `/inventory/${item.id}` %>" style="max-width: 26rem">
  <div class="field">
    <label for="name">Name</label>
    <input type="text" id="name" name="name" value="<%= item.name || '' %>" required autofocus>
    <% if (errors.name) { %><div class="field-error"><%= errors.name %></div><% } %>
  </div>

  <div class="form-row">
    <div class="field">
      <label for="quantity">Quantity</label>
      <input type="number" id="quantity" name="quantity" min="0.1" step="0.1" value="<%= item.quantity || 1 %>" required>
      <% if (errors.quantity) { %><div class="field-error"><%= errors.quantity %></div><% } %>
    </div>
    <div class="field">
      <label for="unit">Unit</label>
      <select id="unit" name="unit">
        <% for (const u of units) { %>
          <option value="<%= u %>" <%= (item.unit || '') === u ? 'selected' : '' %>><%= u === '' ? 'count' : u %></option>
        <% } %>
      </select>
    </div>
  </div>

  <div class="field">
    <label for="category">Category</label>
    <select id="category" name="category">
      <% for (const c of categories) { %>
        <option value="<%= c %>" <%= (item.category || 'Other') === c ? 'selected' : '' %>><%= c %></option>
      <% } %>
    </select>
    <% if (errors.category) { %><div class="field-error"><%= errors.category %></div><% } %>
  </div>

  <div class="field">
    <label for="expires_on">Expiry date</label>
    <input type="date" id="expires_on" name="expires_on" value="<%= item.expires_on || '' %>">
    <div class="hint">Leave empty for items that don't expire.</div>
    <% if (errors.expires_on) { %><div class="field-error"><%= errors.expires_on %></div><% } %>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary"><%= mode === 'add' ? 'Add to pantry' : 'Save changes' %></button>
    <a class="btn btn-plain" href="/inventory">Cancel</a>
  </div>
</form>

<%- include('partials/foot') %>
