<%- include('partials/head', { title: 'Create account' }) %>

<div class="auth-box">
  <div class="auth-brand"><img src="/logo.svg" alt="">PantryAI</div>

  <form method="post" action="/register">
    <div class="field">
      <label for="name">Name</label>
      <input type="text" id="name" name="name" value="<%= values.name || '' %>" required autofocus>
      <% if (errors.name) { %><div class="field-error"><%= errors.name %></div><% } %>
    </div>
    <div class="field">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" value="<%= values.email || '' %>" required>
      <% if (errors.email) { %><div class="field-error"><%= errors.email %></div><% } %>
    </div>
    <div class="field">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" required>
      <div class="hint">At least 8 characters.</div>
      <% if (errors.password) { %><div class="field-error"><%= errors.password %></div><% } %>
    </div>
    <div class="field">
      <label for="confirm">Confirm password</label>
      <input type="password" id="confirm" name="confirm" required>
      <% if (errors.confirm) { %><div class="field-error"><%= errors.confirm %></div><% } %>
    </div>
    <div class="field">
      <label for="dietary">Dietary preference</label>
      <select id="dietary" name="dietary">
        <option value="" <%= !values.dietary ? 'selected' : '' %>>None</option>
        <option value="vegetarian" <%= values.dietary === 'vegetarian' ? 'selected' : '' %>>Vegetarian</option>
        <option value="vegan" <%= values.dietary === 'vegan' ? 'selected' : '' %>>Vegan</option>
        <option value="gluten free" <%= values.dietary === 'gluten free' ? 'selected' : '' %>>Gluten free</option>
      </select>
    </div>
    <button type="submit" class="btn btn-primary btn-block">Create account</button>
  </form>

  <p class="auth-alt">Already have an account? <a href="/login">Log in</a></p>
</div>

<%- include('partials/foot') %>
