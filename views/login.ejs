<%- include('partials/head', { title: 'Log in' }) %>

<div class="auth-box">
  <div class="auth-brand"><img src="/logo.svg" alt="">PantryAI</div>

  <% if (errors.form) { %>
    <div class="flash flash-error"><%= errors.form %></div>
  <% } %>

  <form method="post" action="/login">
    <div class="field">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" value="<%= values.email || '' %>" required autofocus>
    </div>
    <div class="field">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" required>
    </div>
    <button type="submit" class="btn btn-primary btn-block">Log in</button>
  </form>

  <p class="auth-alt">New here? <a href="/register">Create an account</a></p>
</div>

<%- include('partials/foot') %>
